{
  "name": "@kapable/koncierge",
  "version": "0.1.0",
  "description": "Kapable platform onboarding assistant — knowledge distillation + in-console chat agent",
  "private": true,
  "exports": {
    ".": "./src/server.ts",
    "./ui": "./src/ui/index.ts",
    "./bff": "./src/bff/index.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun --watch run src/server.ts",
    "dev:managed": "bun run scripts/dev-with-koncierge.ts",
    "service:install": "./scripts/launchd-service.sh install",
    "service:uninstall": "./scripts/launchd-service.sh uninstall",
    "service:status": "./scripts/launchd-service.sh status",
    "service:logs": "./scripts/launchd-service.sh logs",
    "test": "bun test",
    "distill": "echo 'Run knowledge distillation agents — see PLAN.md Phase 0'",
    "merge": "echo 'Merge subsystem docs into KAPABLE_KNOWLEDGE_BASE.md'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@assistant-ui/react": "^0.12.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
