# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Optional: JWT secret for auth (omit for dev mode — auth bypassed)
# JWT_SECRET=your-shared-secret-or-public-key-pem

# Optional: Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Server port (default: 3033)
# KONCIERGE_PORT=3033

# Optional: CORS origin (default: http://localhost:3000)
# CORS_ORIGIN=http://localhost:3000
