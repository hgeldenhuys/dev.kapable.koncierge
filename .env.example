# Koncierge server environment variables
# Copy to .env and fill in values:  cp .env.example .env

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Required: Shared secret between console BFF and Koncierge server
# Generate with: openssl rand -hex 32
KONCIERGE_SECRET=change-me

# Optional: Server port (default: 3101)
# PORT=3101
